# Core auth
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_ACCESS_CODE=replace-with-admin-access-code

# Durable database (required on Vercel)
# Prefer Supabase pooled connection string for serverless deployments
SUPABASE_DB_URL=postgresql://postgres:password@host:5432/postgres?sslmode=require
# Alternative key supported by the app
# DATABASE_URL=postgresql://postgres:password@host:5432/postgres?sslmode=require

# Optional helper inputs (app can derive SUPABASE_DB_URL from these)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_DB_PASSWORD=replace-with-database-password

# Optional SQLite path for local development
SQLITE_DB_PATH=/workspaces/marketplace-logistics/bakery.db

# Optional critical alert email settings
ALERT_EMAIL_TO=owner@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=alerts@example.com
